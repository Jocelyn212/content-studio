---
import "../styles/global.css";

const { title = "Content Studio" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="bg-studio-cream text-studio-ink antialiased">
    <main class="min-h-screen">
      <slot />
    </main>
  </body>
</html>
