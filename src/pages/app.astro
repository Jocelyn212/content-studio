---
import MainLayout from "../layouts/MainLayout.astro";
import ContentGeneratorApp from "../components/react/app/ContentGeneratorApp.jsx";
---

<MainLayout title="App · Content Studio">
  <section class="mx-auto min-h-screen max-w-6xl px-6 py-10">
    <div class="mb-10 flex items-end justify-between gap-6">
      <div class="space-y-3">
        <p class="text-sm uppercase tracking-[0.2em] text-studio-muted">
          Workspace
        </p>
        <h1 class="text-4xl font-semibold tracking-tight text-studio-ink">
          Crea algo útil y bonito.
        </h1>
        <p class="max-w-2xl text-base leading-7 text-studio-muted">
          Elige qué quieres generar y empieza a dar forma a tu contenido.
        </p>
      </div>
    </div>

    <ContentGeneratorApp client:load />
  </section>
</MainLayout>